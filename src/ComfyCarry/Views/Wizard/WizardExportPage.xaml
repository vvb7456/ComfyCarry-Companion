<Page
    x:Class="ComfyCarry.Views.Wizard.WizardExportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" Padding="0,16,0,16">
        <TextBlock x:Name="Lbl" Text="导出 rclone.conf" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
        <TextBlock x:Name="Hint" TextWrapping="Wrap" Opacity="0.8"
                   Text="打开面板 Setup Wizard 的『云存储』步骤，上传此 rclone.conf 文件。"/>
        <TextBox x:Name="ConfPreview" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                 FontFamily="Consolas" MinHeight="180" MaxHeight="360" Header="rclone.conf 内容"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="SaveBtn" Click="Save_Click" Style="{ThemeResource AccentButtonStyle}" Content="导出 rclone.conf"/>
            <Button x:Name="CopyBtn" Click="Copy_Click" Content="复制内容"/>
            <Button x:Name="BackBtn" Click="Back_Click" Content="上一步"/>
        </StackPanel>
        <TextBlock x:Name="Status" TextWrapping="Wrap"/>
    </StackPanel>
</Page>
