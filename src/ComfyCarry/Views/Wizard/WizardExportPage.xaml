<Page
    x:Class="ComfyCarry.Views.Wizard.WizardExportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24,24,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" Spacing="16" HorizontalAlignment="Left">
            <TextBlock x:Name="Lbl" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
            <TextBlock x:Name="Hint" TextWrapping="Wrap" Opacity="0.8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBox x:Name="ConfPreview" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             FontFamily="Consolas" MinHeight="180" MaxHeight="360"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="SaveBtn" Click="Save_Click" Style="{ThemeResource AccentButtonStyle}"/>
                        <Button x:Name="CopyBtn" Click="Copy_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="Status" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="BackBtn" Click="Back_Click"/>
                <Button x:Name="FinishBtn" Click="Finish_Click" Style="{ThemeResource AccentButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
