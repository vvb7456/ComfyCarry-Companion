<Page
    x:Class="ComfyCarry.Views.Wizard.WizardParamsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" Padding="0,16,0,16">
        <TextBlock x:Name="Lbl" Text="填写参数" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
        <StackPanel x:Name="FieldsPanel" Spacing="12"/>
        <InfoBar x:Name="OAuthInfo" Severity="Informational" IsOpen="False"
                 Title="需要浏览器授权"
                 Message="下一步将打开浏览器完成登录。"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BackBtn" Click="Back_Click" Content="上一步"/>
            <Button x:Name="NextBtn" Click="Next_Click" Style="{ThemeResource AccentButtonStyle}" Content="下一步"/>
        </StackPanel>
    </StackPanel>
</Page>
