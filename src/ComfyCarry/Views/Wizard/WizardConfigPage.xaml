<Page
    x:Class="ComfyCarry.Views.Wizard.WizardConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComfyCarry.Views.Wizard">
    <ScrollViewer Padding="24,24,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" Spacing="16" HorizontalAlignment="Left">
            <TextBlock x:Name="Lbl" Style="{ThemeResource BodyStrongTextBlockStyle}"/>

            <!-- 非参数面板（OAuth 类型） -->
            <Border x:Name="OAuthPanel"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20"
                    Visibility="Collapsed">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="OAuthHint" TextWrapping="Wrap" Opacity="0.8"/>
                    <ProgressRing x:Name="Busy" IsActive="False" Width="40" Height="40"/>
                    <TextBlock x:Name="Status" TextWrapping="Wrap"/>
                    <ListView x:Name="ChoicesList" Visibility="Collapsed" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ConfigChoiceVM">
                                <RadioButton Content="{x:Bind Label}" Tag="{x:Bind Id}" Click="Choice_Click"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="AuthorizeBtn" Click="Authorize_Click" Style="{ThemeResource AccentButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 参数面板（非 OAuth 类型） -->
            <Border x:Name="ParamsPanel"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20"
                    Visibility="Collapsed">
                <StackPanel x:Name="FieldsPanel" Spacing="12"/>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="BackBtn" Click="Back_Click"/>
                <Button x:Name="SaveBtn" Click="Save_Click" Style="{ThemeResource AccentButtonStyle}" Visibility="Collapsed"/>
                <Button x:Name="NextBtn" Click="Next_Click" Style="{ThemeResource AccentButtonStyle}" Visibility="Collapsed"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
