<Page
    x:Class="ComfyCarry.Views.Wizard.WizardConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComfyCarry.Views.Wizard">
    <Grid RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" Padding="40,32,40,16" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="640" HorizontalAlignment="Center" Spacing="16">
                <TextBlock x:Name="Lbl" Style="{ThemeResource SubtitleTextBlockStyle}"/>

                <!-- OAuth 面板 -->
                <StackPanel x:Name="OAuthPanel" Spacing="12" Visibility="Collapsed">
                    <TextBlock x:Name="OAuthHint" TextWrapping="Wrap" Opacity="0.8"/>
                    <Button x:Name="AuthorizeBtn" Click="Authorize_Click" Style="{ThemeResource AccentButtonStyle}"/>
                </StackPanel>

                <!-- 参数面板 -->
                <StackPanel x:Name="ParamsPanel" Spacing="12" Visibility="Collapsed">
                    <StackPanel x:Name="FieldsPanel" Spacing="12"/>
                    <Button x:Name="SaveBtn" Click="Save_Click" Style="{ThemeResource AccentButtonStyle}" Visibility="Collapsed"/>
                </StackPanel>

                <!-- 选项列表（NeedChoice 时显示） -->
                <StackPanel x:Name="ChoicePanel" Spacing="8" Visibility="Collapsed">
                    <TextBlock x:Name="ChoiceHint" TextWrapping="Wrap"/>
                    <ListView x:Name="ChoicesList" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ConfigChoiceVM">
                                <RadioButton Content="{x:Bind Label}" Tag="{x:Bind Id}" Click="Choice_Click"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- 建目录 checkbox -->
                <CheckBox x:Name="CreateTreeCheck" IsChecked="True"/>

                <!-- 状态区 -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ProgressRing x:Name="Busy" IsActive="False" Width="24" Height="24" Visibility="Collapsed"/>
                    <TextBlock x:Name="Status" TextWrapping="Wrap" VerticalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 固定底栏 -->
        <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="40,12">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Button x:Name="BackBtn" Grid.Column="0" Click="Back_Click"
                        Content="上一步" Padding="20,8" MinWidth="100"/>
                <Button x:Name="NextBtn" Grid.Column="2" Click="Next_Click"
                        Style="{ThemeResource AccentButtonStyle}" Padding="20,8" MinWidth="120"
                        Content="完成" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Page>
