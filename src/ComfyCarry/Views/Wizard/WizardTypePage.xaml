<Page
    x:Class="ComfyCarry.Views.Wizard.WizardTypePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" Padding="0,16,0,16">
        <TextBlock x:Name="Lbl" Text="选择云类型" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
        <RadioButtons x:Name="TypeRadios" MaxColumns="1" SelectionChanged="Type_SelectionChanged"/>
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="NameLabel" Grid.Row="0" Grid.Column="0" Text="Remote 名称" VerticalAlignment="Center"/>
                <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" PlaceholderText="my-onedrive" Width="280"
                         TextChanged="Name_TextChanged"/>
                <TextBlock x:Name="NameErr" Grid.Row="1" Grid.Column="1" Foreground="OrangeRed" Visibility="Collapsed"/>
            </Grid>
        </Grid>
        <StackPanel Spacing="4">
            <TextBlock x:Name="ProxyLabel" Text="代理（可选）"/>
            <TextBox x:Name="ProxyBox" PlaceholderText="http://127.0.0.1:7890" Width="360"
                     TextChanged="Proxy_TextChanged"/>
            <TextBlock x:Name="ProxyHint" Opacity="0.6" TextWrapping="Wrap" Text="形如 http://127.0.0.1:7890，作为 rclone 子进程的 HTTP_PROXY/HTTPS_PROXY。"/>
        </StackPanel>
        <Button x:Name="NextBtn" Click="Next_Click" Style="{ThemeResource AccentButtonStyle}" Content="下一步"/>
    </StackPanel>
</Page>
