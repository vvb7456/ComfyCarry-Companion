<Page
    x:Class="ComfyCarry.Views.Wizard.WizardTypePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24,24,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="720" Spacing="16" HorizontalAlignment="Left">
            <TextBlock x:Name="Lbl" Style="{ThemeResource BodyStrongTextBlockStyle}"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <RadioButtons x:Name="TypeRadios" MaxColumns="1" SelectionChanged="Type_SelectionChanged"/>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="CancelBtn" Click="Cancel_Click"/>
                <Button x:Name="NextBtn" Click="Next_Click" Style="{ThemeResource AccentButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
