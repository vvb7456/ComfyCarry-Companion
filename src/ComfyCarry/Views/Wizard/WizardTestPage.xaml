<Page
    x:Class="ComfyCarry.Views.Wizard.WizardTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="16" Padding="0,16,0,16">
        <TextBlock x:Name="Lbl" Text="连接测试" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
        <Button x:Name="TestBtn" Click="Test_Click" Style="{ThemeResource AccentButtonStyle}" Content="测试连接"/>
        <ProgressRing x:Name="Busy" IsActive="False" Width="40" Height="40"/>
        <TextBlock x:Name="Result" TextWrapping="Wrap" FontFamily="Consolas"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BackBtn" Click="Back_Click" Content="上一步"/>
            <Button x:Name="NextBtn" Click="Next_Click" Style="{ThemeResource AccentButtonStyle}" Content="下一步"/>
        </StackPanel>
    </StackPanel>
</Page>
