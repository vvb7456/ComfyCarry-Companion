<ContentDialog
    x:Class="ComfyCarry.Views.ConnectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="连接实例"
    PrimaryButtonText="连接并保存"
    CloseButtonText="取消"
    DefaultButton="Primary">
    <StackPanel Spacing="12" Width="440">
        <TextBox x:Name="UrlBox" Header="面板 URL" PlaceholderText="https://comfy.example.com"/>
        <PasswordBox x:Name="PwdBox" Header="面板密码"/>
        <TextBox x:Name="LabelBox" Header="显示名（可选）" PlaceholderText="runpod-a1b2"/>
        <TextBlock x:Name="Status" TextWrapping="Wrap" Visibility="Collapsed"/>
        <ProgressRing x:Name="Busy" IsActive="False" Width="32" Height="32"/>
    </StackPanel>
</ContentDialog>
