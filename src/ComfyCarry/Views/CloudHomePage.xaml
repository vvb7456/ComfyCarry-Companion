<Page
    x:Class="ComfyCarry.Views.CloudHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComfyCarry.Views"
    NavigationCacheMode="Required">
    <Grid Padding="40,32,40,16">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <TextBlock x:Name="TitleText" Style="{ThemeResource SubtitleTextBlockStyle}"/>
            <InfoBar x:Name="RcloneMissingBar" Severity="Warning" IsOpen="False"/>

            <!-- 固定大小卡片 -->
            <Border Width="560" MinHeight="400"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <Grid>
                    <!-- 空状态 -->
                    <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xE753;" FontSize="40" Opacity="0.3" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="EmptyTitle" HorizontalAlignment="Center" Opacity="0.6"/>
                        <Button x:Name="EmptyAddBtn" Click="NewRemote_Click" HorizontalAlignment="Center"
                                Style="{ThemeResource AccentButtonStyle}" Padding="20,8" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                <TextBlock x:Name="EmptyAddLabel"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 有数据：列表 + 底部添加按钮 -->
                    <Grid x:Name="DataState" RowDefinitions="*,Auto" Visibility="Collapsed">
                        <ListView x:Name="RemotesList" Grid.Row="0" SelectionMode="None" IsItemClickEnabled="False">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:RemoteVM">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="4,10" ColumnSpacing="12">
                                        <Image Source="{x:Bind LogoUri}" Width="24" Height="24" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Tag="{x:Bind Name}" Click="Delete_Click"
                                                Padding="12,4" FontSize="12" Content="删除" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- 添加按钮：卡片内最后一项 -->
                        <Button x:Name="NewRemoteBtn" Grid.Row="1" Click="NewRemote_Click"
                                HorizontalAlignment="Stretch" Margin="0,12,0,0" Padding="12,10">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                <TextBlock x:Name="NewRemoteLabel"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- 导出按钮：卡片外，右对齐，Accent -->
            <Button x:Name="ExportBtn" Click="Export_Click" HorizontalAlignment="Right"
                    Style="{ThemeResource AccentButtonStyle}" IsEnabled="False" Padding="20,8">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xEDE1;" FontSize="14"/>
                    <TextBlock x:Name="ExportLabel"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Page>
