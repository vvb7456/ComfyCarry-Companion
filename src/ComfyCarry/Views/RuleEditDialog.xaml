<ContentDialog
    x:Class="ComfyCarry.Views.RuleEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="编辑规则"
    PrimaryButtonText="保存"
    CloseButtonText="取消"
    DefaultButton="Primary">
    <ScrollViewer MaxHeight="560" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Width="520">
            <TextBox x:Name="NameBox" Header="名称"/>
            <TextBox x:Name="RemotePathBox" Header="远程子文件夹（留空=根目录）" PlaceholderText="例：子文件夹，留空取 output 根"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox x:Name="LocalPathBox" Grid.Column="0" Header="本机目标文件夹" PlaceholderText="D:\ComfyCarry\out\" HorizontalAlignment="Stretch"/>
                <Button x:Name="BrowseBtn" Grid.Column="1" Click="Browse_Click" Content="浏览…" VerticalAlignment="Bottom"/>
            </Grid>
            <ComboBox x:Name="MethodBox" Header="方式" HorizontalAlignment="Stretch">
                <x:String>copy</x:String>
                <x:String>move</x:String>
                <x:String>sync</x:String>
            </ComboBox>
            <TextBox x:Name="FiltersBox" Header="文件类型（扩展名，空格分隔）" PlaceholderText="png jpg jpeg mp4"/>
            <ComboBox x:Name="TriggerBox" Header="触发" HorizontalAlignment="Stretch">
                <x:String>watch</x:String>
                <x:String>manual</x:String>
            </ComboBox>
            <NumberBox x:Name="IntervalBox" Header="间隔（秒）" Minimum="30" Maximum="86400" Value="300" HorizontalAlignment="Stretch"/>
            <ToggleSwitch x:Name="EnabledSwitch" Header="启用" IsOn="True"/>
            <TextBlock x:Name="MoveWarn" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap"
                       Text="移动方式会在取回后删除远程原文件。" Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
