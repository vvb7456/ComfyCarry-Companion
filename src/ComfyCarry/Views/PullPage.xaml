<Page
    x:Class="ComfyCarry.Views.PullPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComfyCarry.Views"
    NavigationCacheMode="Required">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- 顶部：实例切换 + 连接 -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="36,16,36,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ComboBox x:Name="InstanceBox" Header="实例" Width="280" SelectionChanged="Instance_SelectionChanged"/>
                <Button x:Name="ConnectBtn" Click="Connect_Click" Content="连接实例" VerticalAlignment="Bottom"/>
            </StackPanel>
            <Button x:Name="RefreshBtn" Grid.Column="1" Click="Refresh_Click" Content="刷新" VerticalAlignment="Bottom"/>
        </Grid>

        <!-- 介绍 + 总进度 -->
        <StackPanel Grid.Row="1" Padding="36,0,36,12" Spacing="6">
            <TextBlock x:Name="IntroText" TextWrapping="Wrap" Opacity="0.8"
                       Text="把实例产物额外拉一份到本机，与你在面板配置的网盘同步互不影响、可并存。"/>
            <InfoBar x:Name="NoInstanceBar" Severity="Informational" IsOpen="False"
                     Message="尚未连接任何实例。请在顶部切换或到设置页添加。"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" x:Name="ProgressRow" Visibility="Collapsed">
                <ProgressBar x:Name="TotalProgress" Value="0" Maximum="100"/>
                <TextBlock x:Name="ProgressText" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- 规则列表 -->
        <ScrollViewer Grid.Row="2" Padding="36,0,36,12" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="拉取规则" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="NewRuleBtn" Click="NewRule_Click" Content="新建规则"/>
                    </StackPanel>
                </Grid>
                <ListView x:Name="RulesList" IsItemClickEnabled="True" ItemClick="Rule_Click">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:PullRuleVM">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" Padding="8" RowSpacing="2">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Opacity="0.7" Text="{x:Bind Summary}" FontSize="12"/>
                                <ProgressBar Grid.Row="2" Grid.Column="0" Value="{x:Bind Progress}" Maximum="100" Width="320" HorizontalAlignment="Left"/>
                                <StackPanel Grid.RowSpan="3" Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind StatusText}" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
                                    <Button Content="立即拉取" Tag="{x:Bind RuleId}" Click="RunOnce_Click" Padding="8,4"/>
                                    <Button Content="编辑" Tag="{x:Bind RuleId}" Click="EditRule_Click" Padding="8,4"/>
                                    <Button Content="打开文件夹" Tag="{x:Bind LocalPath}" Click="OpenFolder_Click" Padding="8,4"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>

        <!-- 产物列表 -->
        <Expander Grid.Row="3" Header="产物列表（WebDAV）" HorizontalAlignment="Stretch" ExpandDirection="Up" IsExpanded="False">
            <local:ArtifactListView x:Name="Artifacts"/>
        </Expander>
    </Grid>
</Page>
