<Page x:Class="ComfyCarry.Views.PullPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ComfyCarry.Views"
      NavigationCacheMode="Required">
    <Grid>
        <!-- 空状态 -->
        <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" MaxWidth="480">
            <FontIcon Glyph="&#xE896;" FontSize="48" Opacity="0.4" HorizontalAlignment="Center"/>
            <TextBlock x:Name="EmptyTitle" Style="{ThemeResource SubtitleTextBlockStyle}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="EmptyDesc" TextWrapping="Wrap" HorizontalAlignment="Center" Opacity="0.7" TextAlignment="Center"/>
            <Button x:Name="EmptyConnectBtn" Click="Connect_Click" HorizontalAlignment="Center"
                    Style="{ThemeResource AccentButtonStyle}" Padding="24,10"/>
        </StackPanel>

        <!-- 主内容 -->
        <ScrollViewer x:Name="MainContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
            <StackPanel Padding="40,32,40,16" MaxWidth="720" HorizontalAlignment="Center" Spacing="20">
                <!-- 标题 -->
                <StackPanel Spacing="4">
                    <TextBlock x:Name="TitleText" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:Name="SubtitleText" Opacity="0.7"/>
                </StackPanel>

                <!-- 连接条 -->
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12" VerticalAlignment="Center">
                    <ComboBox x:Name="InstanceBox" Width="220" SelectionChanged="Instance_SelectionChanged"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="Gray"/>
                        <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="DavHostText" Grid.Column="2" VerticalAlignment="Center" Opacity="0.5" FontSize="12" TextTrimming="CharacterEllipsis"/>
                    <Button x:Name="AddInstanceBtn" Grid.Column="3" Click="Connect_Click" Padding="12,6"/>
                </Grid>

                <!-- 自动取回条 -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <ToggleSwitch x:Name="AutoPullSwitch" Toggled="AutoPull_Toggled" OnContent="" OffContent="" MinWidth="80"/>
                    <TextBlock x:Name="AutoPullDesc" Grid.Column="1" VerticalAlignment="Center" Opacity="0.6" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="PullStatusText" Grid.Column="2" VerticalAlignment="Center" FontSize="12"/>
                </Grid>

                <!-- 规则区 -->
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock x:Name="RulesHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                        <Button x:Name="NewRuleBtn" Grid.Column="1" Click="NewRule_Click" Style="{ThemeResource AccentButtonStyle}" Padding="16,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                <TextBlock x:Name="NewRuleLabel"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock x:Name="NoRulesText" Visibility="Collapsed" Opacity="0.6" TextWrapping="Wrap"/>

                    <ListView x:Name="RulesList" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:PullRuleVM">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel Spacing="8">
                                        <!-- 第一行：名称 + chips + 启用 -->
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind MethodLabel}" FontSize="11" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                                </Border>
                                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind TriggerLabel}" FontSize="11"/>
                                                </Border>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" IsChecked="{x:Bind Enabled, Mode=TwoWay}"
                                                      Click="RuleEnabled_Click" Tag="{x:Bind RuleId}" MinWidth="0"/>
                                        </Grid>
                                        <!-- 第二行：路径 -->
                                        <TextBlock Text="{x:Bind PathSummary}" Opacity="0.7" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <!-- 第三行：进度（活跃时） -->
                                        <Grid Visibility="{x:Bind ProgressVisible}" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <ProgressBar Value="{x:Bind Progress}" Maximum="100"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind ProgressLabel}" FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
                                        <!-- 第四行：上次结果 + 操作 -->
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Text="{x:Bind LastRunText}" Opacity="0.5" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <Button Content="{x:Bind RunLabel}" Tag="{x:Bind RuleId}" Click="RunOnce_Click" Padding="10,4" FontSize="12"/>
                                                <Button Content="{x:Bind EditLabel}" Tag="{x:Bind RuleId}" Click="EditRule_Click" Padding="10,4" FontSize="12"/>
                                                <Button Content="{x:Bind OpenLabel}" Tag="{x:Bind LocalPath}" Click="OpenFolder_Click" Padding="10,4" FontSize="12"/>
                                                <Button Content="{x:Bind DeleteLabel}" Tag="{x:Bind RuleId}" Click="DeleteRule_Click" Padding="10,4" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
