<Page
    x:Class="ComfyCarry.Views.CloudSetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComfyCarry.Views"
    xmlns:wiz="using:ComfyCarry.Views.Wizard"
    NavigationCacheMode="Required">
    <Grid RowDefinitions="Auto,*">
        <!-- 步骤指示条（自绘，非可点击）。仅向导步骤页显示 -->
        <Border x:Name="StepBar" Grid.Row="0" Visibility="Collapsed"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Padding="24,10,24,10" HorizontalAlignment="Stretch">
            <StackPanel x:Name="StepBarPanel" Orientation="Horizontal" Spacing="20"/>
        </Border>
        <Frame x:Name="HostFrame" Grid.Row="1" CacheSize="4"/>
    </Grid>
</Page>
