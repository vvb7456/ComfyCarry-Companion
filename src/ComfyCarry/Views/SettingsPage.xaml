<Page
    x:Class="ComfyCarry.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComfyCarry.Views"
    NavigationCacheMode="Required">
    <ScrollViewer Padding="36,24,36,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="24">
            <TextBlock x:Name="Title" Text="设置" Style="{ThemeResource SubtitleTextBlockStyle}"/>

            <!-- 实例管理 -->
            <StackPanel Spacing="8">
                <TextBlock x:Name="InstancesHeader" Text="实例管理" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <ListView x:Name="InstanceList" ItemsSource="{x:Bind Instances}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:InstanceVM">
                            <Grid ColumnDefinitions="*,Auto" Padding="6">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind BaseUrl}" Opacity="0.7" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Button Content="设为当前" Tag="{x:Bind Id}" Click="SetCurrent_Click" Padding="6,2"/>
                                    <Button Content="删除" Tag="{x:Bind Id}" Click="DeleteInstance_Click" Padding="6,2"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- 语言 -->
            <StackPanel Spacing="6">
                <TextBlock x:Name="LangHeader" Text="语言"/>
                <RadioButtons x:Name="LangRadios" SelectionChanged="Lang_SelectionChanged">
                    <RadioButton Content="简体中文" Tag="zh-CN"/>
                    <RadioButton Content="English" Tag="en-US"/>
                </RadioButtons>
            </StackPanel>

            <!-- 主题 -->
            <StackPanel Spacing="6">
                <TextBlock x:Name="ThemeHeader" Text="主题"/>
                <RadioButtons x:Name="ThemeRadios" SelectionChanged="Theme_SelectionChanged">
                    <RadioButton x:Name="ThemeSystem" Content="跟随系统" Tag="System"/>
                    <RadioButton x:Name="ThemeLight" Content="浅色" Tag="Light"/>
                    <RadioButton x:Name="ThemeDark" Content="深色" Tag="Dark"/>
                </RadioButtons>
            </StackPanel>

            <!-- 其它选项 -->
            <StackPanel Spacing="6">
                <ToggleSwitch x:Name="AutoStartSwitch" Header="开机自启" Toggled="AutoStart_Toggled"/>
                <ToggleSwitch x:Name="CloseToTraySwitch" Header="关闭窗口时最小化到托盘" Toggled="CloseToTray_Toggled"/>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="4">
                <TextBlock x:Name="AboutHeader" Text="关于" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                <TextBlock x:Name="VersionLine"/>
                <TextBlock Opacity="0.7" TextWrapping="Wrap" Text="ComfyCarry Companion — 把 ComfyUI 产物取回本机的 Windows 桌面客户端。不使用 Electron，基于 WinUI 3 / .NET 8。"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
