<Window
    x:Class="ComfyCarry.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ComfyCarry.Views"
    Title="ComfyCarry Companion">
    <Grid RowDefinitions="Auto,*">
        <!-- 自绘标题栏：右侧留白让系统三键叠上去不撞 -->
        <Border x:Name="AppTitleBar" Grid.Row="0" Height="40" Padding="14,0,0,0"
                Background="Transparent"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image Source="Assets/app.ico" Width="16" Height="16"/>
                <TextBlock x:Name="AppTitleText" Text="ComfyCarry Companion"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <NavigationView
            x:Name="Nav"
            Grid.Row="1"
            PaneDisplayMode="Left"
            OpenPaneLength="200"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="Nav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="cloud">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE753;"/>
                    </NavigationViewItem.Icon>
                    <TextBlock x:Name="NavCloudLabel" Text="云存储配置"/>
                </NavigationViewItem>
                <NavigationViewItem Tag="pull">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;"/>
                    </NavigationViewItem.Icon>
                    <TextBlock x:Name="NavPullLabel" Text="产物取回"/>
                </NavigationViewItem>
                <NavigationViewItem Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                    <TextBlock x:Name="NavSettingsLabel" Text="设置"/>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
